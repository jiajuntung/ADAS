<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <!-- Back camera preview.
         scaleType is set to FIT_CENTER in code so the WHOLE analysis frame is
         visible: under the default FILL_CENTER the top and bottom 20% of a 4:3
         camera image are cropped away in this landscape view, which is how the
         LDW strip ended up analysing the car's bonnet unseen for three tests. -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Road safety overlay -->
    <com.example.adas_fyp.SafetyOverlayView
        android:id="@+id/safetyOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Front camera small preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/frontPreviewView"
        android:layout_width="220dp"
        android:layout_height="140dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="#80000000" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="⚙"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:background="#66000000"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp" />

    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="#CC000000"
        android:visibility="gone"
        android:layout_gravity="top|end"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btnStatusMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status ON" />

        <Button
            android:id="@+id/btnPerformanceMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode: Normal" />

        <!-- Which side of the FRONT CAMERA IMAGE the driver sits on.
             Malaysia is right-hand drive, but front-camera mirroring and
             rotation vary by device, so this is verifiable and flippable
             rather than hard-coded. Watch "DMS drv[R]@0.xx faces:n" in the
             status panel and flip if it locks onto the passenger. -->
        <Button
            android:id="@+id/btnDriverSide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Driver: Left" />
    </LinearLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADAS Running"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="#80000000"
        android:padding="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_gravity="top|start" />

    <!-- FPS / debug text -->
    <TextView
        android:id="@+id/fpsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS: 0"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#80000000"
        android:padding="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="70dp"
        android:layout_gravity="top|start" />

    <!-- Warning message -->
    <TextView
        android:id="@+id/warningText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BRAKE!"
        android:textColor="@android:color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:background="#CCFF0000"
        android:padding="20dp"
        android:visibility="gone"
        android:layout_gravity="center" />

    <!-- Bottom test buttons -->
    <LinearLayout
        android:id="@+id/testButtonPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#80000000">

        <Button
            android:id="@+id/btnTestFCW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Test FCW" />

        <Button
            android:id="@+id/btnTestLDW"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Test LDW" />

        <Button
            android:id="@+id/btnTestDMS"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Test DMS" />

        <Button
            android:id="@+id/btnSwitchCamera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Switch Cam" />
    </LinearLayout>

</FrameLayout>